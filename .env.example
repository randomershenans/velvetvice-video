# Required for the automated pipeline (pipeline.mjs)

# xAI / Grok — generates the story package (title, subtitle, body, caption)
# and the narration audio.
GROK_API_KEY=xai-...

# Google Drive upload (recommended). Each clip + its cover-frame thumbnail
# land in your Drive folder; the Make.com scenario fetches them from there.
# GOOGLE_SERVICE_ACCOUNT: the full service-account JSON key, on one line.
# DRIVE_FOLDER_ID: id of a Drive folder shared with the service account.
GOOGLE_SERVICE_ACCOUNT={"type":"service_account",...}
DRIVE_FOLDER_ID=

# Make.com webhook — receives a POST per finished clip with title, caption,
# Drive file IDs for the video + thumbnail, vibe, heat, voice, and timestamp.
# The Make.com scenario fetches the file from Drive and posts it to
# Instagram Reels + TikTok. Leave empty to skip social posting (clips still
# land in Drive and output/).
MAKE_WEBHOOK_URL=

# How many clips per pipeline run. The scheduled workflow runs 5 times a day
# producing 1 clip each. Bump locally for batch testing.
CLIP_COUNT=1
