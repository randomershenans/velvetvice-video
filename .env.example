# Required for the automated pipeline (pipeline.mjs)

# xAI / Grok — generates the story package and narration audio.
GROK_API_KEY=xai-...

# Google Drive (OAuth — uses your personal Drive's 15GB quota).
# Setup:
#   1. Google Cloud → APIs & Services → Credentials → OAuth client (Desktop)
#   2. OAuth consent screen → add your email as a Test User
#   3. Run: GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=... \
#          node scripts/get-drive-token.mjs
#   4. Paste the printed refresh token as GOOGLE_REFRESH_TOKEN
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
DRIVE_FOLDER_ID=

# Instagram (Meta Graph API) — for posting Reels.
META_ACCESS_TOKEN=
META_IG_BUSINESS_ID=

# TikTok (Content Posting API) — refresh-token grant flow.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# How many clips per pipeline run. The workflow fires 5 times a day with
# CLIP_COUNT=1 — one clip per run, posted (or staged in Drive) immediately.
CLIP_COUNT=1
