# Required for the automated pipeline (pipeline.mjs)

# xAI / Grok — generates the hook scripts and narration audio
GROK_API_KEY=xai-...

# Google Drive upload (optional — without it, clips just stay in output/)
# GOOGLE_SERVICE_ACCOUNT: the full service-account JSON key, on one line
# DRIVE_FOLDER_ID: id of a Drive folder shared with the service account
GOOGLE_SERVICE_ACCOUNT={"type":"service_account",...}
DRIVE_FOLDER_ID=

# How many clips per run (default 3 locally, the workflow passes 5)
CLIP_COUNT=3
