# Required for the automated pipeline (pipeline.mjs)

# xAI / Grok — generates the story package and narration audio.
GROK_API_KEY=xai-...

# Google Drive — hosts the rendered videos so Meta and TikTok can fetch them
# when posting. Files are made publicly readable after upload.
# GOOGLE_SERVICE_ACCOUNT: the full service-account JSON, on one line
# DRIVE_FOLDER_ID: id of a Drive folder shared with the service account
GOOGLE_SERVICE_ACCOUNT=
DRIVE_FOLDER_ID=

# Instagram (Meta Graph API) — for posting Reels.
# META_ACCESS_TOKEN: System User token (instagram_content_publish scope, never expires)
# META_IG_BUSINESS_ID: the IG business account id from /me/accounts
META_ACCESS_TOKEN=
META_IG_BUSINESS_ID=

# TikTok (Content Posting API) — refresh-token grant flow. Access tokens are
# refreshed on each run, so we only store the long-lived refresh token.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# How many clips per pipeline run. The workflow fires 5 times a day (08, 12,
# 16, 20, 23 UTC) with CLIP_COUNT=1 — one clip per run, posted immediately.
CLIP_COUNT=1
