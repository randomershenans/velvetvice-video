# Required for the automated pipeline (pipeline.mjs)

# xAI / Grok — generates the story package (title, subtitle, body, caption)
# and the narration audio.
GROK_API_KEY=xai-...

# Ayrshare — hosts the rendered video and schedules posts to Instagram +
# TikTok. Get your key at https://app.ayrshare.com → API Key. Link your IG
# and TikTok accounts in the Ayrshare dashboard once and forget it.
AYRSHARE_API_KEY=

# Google Drive backup (OPTIONAL). When set, each clip + thumbnail also
# archive to your Drive folder. Skip if you don't need an off-Ayrshare copy.
GOOGLE_SERVICE_ACCOUNT=
DRIVE_FOLDER_ID=

# How many clips per pipeline run. The scheduled workflow runs once a day
# generating 5 clips and spacing them across the day on Ayrshare.
CLIP_COUNT=5

# Posting cadence — first post N hours after generation, then every M hours.
# Default 1h start + 3h interval → 5 posts spread over ~13 hours.
POST_START_HOURS=1
POST_INTERVAL_HOURS=3
